# AI Vlog v15 稳定画面 + 视觉差异化版
NODE_ENV=development
PORT=8787
WEB_ORIGIN=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8787
VITE_API_BASE=http://localhost:8787
PROJECT_ROOT=

# v13 线上驱动。local/file/json 便于本地跑；redis/postgres/s3 用于线上。
QUEUE_DRIVER=file
DATABASE_DRIVER=json
STORAGE_DRIVER=local
STORAGE_DIR=

# Redis / BullMQ 线上队列
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=1
WORKER_POLL_INTERVAL_MS=1200

# PostgreSQL / Prisma 线上数据库
DATABASE_URL=postgresql://ai_vlog:ai_vlog@localhost:5432/ai_vlog?schema=public

# S3 / OSS / MinIO 对象存储
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ai-vlog
S3_ACCESS_KEY_ID=ai_vlog_minio
S3_SECRET_ACCESS_KEY=ai_vlog_minio_secret
S3_FORCE_PATH_STYLE=true
STORAGE_PUBLIC_BASE_URL=http://localhost:9000/ai-vlog

# 用户登录 / 作品权限
JWT_SECRET=change-me-to-a-long-random-secret
AUTH_REQUIRED=true
ALLOW_ANONYMOUS=false

# Qwen：正式生成必须使用真实 Key，不提供固定兜底文案 / mock 生成。
QWEN_API_KEY=你的新QwenKey
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_VL_MODEL=qwen-vl-plus
QWEN_TEXT_MODEL=qwen-plus
MOCK_QWEN=false

# Remotion 渲染
RENDER_CODEC=h264
RENDER_FPS=30
RENDER_WIDTH=1080
RENDER_HEIGHT=1920
RENDER_DURATION_SECONDS=45
PREVIEW_DURATION_SECONDS=18
RENDER_CONCURRENCY=1
MAX_VERSIONS=6
QUALITY_THRESHOLD=82
AUTO_REGENERATE_MAX=1

# v13 稳定验收 / 质量观测
PREFERENCE_LEARNING=true
ANALYTICS_ENABLED=true

# v13 QA / Observability
DIRECTOR_PLAN_SELF_REPAIR=true
METRICS_ENABLED=true


# v20 预览稳定策略：先保证“极速预览”能尽快出来。
# 不再默认把所有素材强制 mci 插帧到 60fps，否则普通电脑会长时间卡在 10% rendering。
NORMALIZE_VIDEO_PROXIES=true
RENDER_FPS=30
MIN_RENDER_FPS=30
VIDEO_PROXY_STRATEGY=adaptive-fast-preview
ALWAYS_NORMALIZE_VIDEO_PROXIES=false
VIDEO_PROXY_INTERPOLATION=fps
VIDEO_PROXY_ENABLE_MCI=false
VIDEO_PROXY_TIMEOUT_MS=120000
VIDEO_PROXY_PRESET=veryfast
VIDEO_PROXY_CRF=20
HIGH_MOTION_PROXY=false
HIGH_MOTION_PLAYBACK_RATE=0.82
HIGH_MOTION_DURATION_BOOST=1.15
